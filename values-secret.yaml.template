# Secrets documentation:
# https://validatedpatterns.io/learn/secrets-management-in-the-validated-patterns-framework/
version: "2.0"

secrets:
  - name: gitlab-credentials
    fields:
      - name: root-password
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: runner-token
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  - name: rhbk-credentials
    fields:
      - name: admin-password
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: db-password
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  - name: developer-hub-secrets
    fields:
      - name: oidc-client-secret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: session-secret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: gitlab-token
        # Placeholder until PostSync gitlab-token-setup patches Vault with a real PAT.
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  - name: minio-credentials
    fields:
      - name: accesskey
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: secretkey
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  - name: maas-credentials
    fields:
      - name: api-key
        value: "MaaS/LiteLLM API key (optional, for OpenShift AI models)"

  - name: workshop-registration
    fields:
      - name: adminToken
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Platform API key for AI Gateway (Lightspeed + NeuroFace internal services).
  # Path: secret/hub/ai-gateway-platform-keys → secret/data/hub/ai-gateway-platform-keys
  - name: ai-gateway-platform-keys
    fields:
      - name: platformApiKey
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  - name: models-as-a-service-db
    fields:
      - name: username
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: password
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: database
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Argo CD MCP tokens (hub/east/west ai-agent local user + URLs).
  # Placeholders until PostSync sync Jobs patch Vault with real values.
  # Path: secret/hub/argocd-mcp-tokens → secret/data/hub/argocd-mcp-tokens
  - name: argocd-mcp-tokens
    fields:
      - name: hub-token
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: hub-url
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: east-token
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: east-url
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: west-token
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
      - name: west-url
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Keycloak realm client secrets. rhbk-iam reads ONE Vault secret per user
  # per realm at secret/hub/keycloak/realms/<realm>/user<N> (a separate
  # top-level `name:` entry each, NOT fields grouped under one entry) --
  # see charts/all/rhbk-iam/templates/externalsecret-realm-clients.yaml.
  # Console/Pattern CR installs get these auto-seeded for the full
  # userCount by the vault-secrets-bootstrap chart. For a CLI install,
  # repeat this entry for every user (1..userCount) in each realm below
  # (only user1 shown per realm; add more or use `make load-secrets` with
  # a generated values-secret file for userCount > 1):
  - name: keycloak/realms/neuroface/user1
    fields:
      - name: clientSecret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
  - name: keycloak/realms/maas/user1
    fields:
      - name: clientSecret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy
  - name: keycloak/realms/cv/user1
    fields:
      - name: clientSecret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # Backstage/Developer Hub Keycloak Admin REST provisioner client (realm cv).
  # Used by the oidc-credentials-self-service scaffolder template to create
  # per-user OIDC clients on demand. Consumed by both
  # charts/all/rhbk-iam/templates/externalsecret-backstage-provisioner.yaml
  # (realm-import placeholder) and
  # charts/all/developer-hub/templates/externalsecret-keycloak-provisioner.yaml
  # (RHDH backend env vars) — both must read the exact same value, or the
  # scaffolder template fails Keycloak Admin API auth with
  # "unauthorized_client (Invalid client or Invalid client credentials)".
  - name: keycloak/realms/cv/backstage-provisioner
    fields:
      - name: clientSecret
        onMissingValue: generate
        vaultPolicy: validatedPatternDefaultPolicy

  # spoke-credentials: only needed when spokeCredentials.mode=vault.
  # When mode=inline, pass tokens via Pattern CR extraParameters instead.
  # When mode=secret, pre-create the K8s Secret manually.
  #
  # IMPORTANT: The token must come from the acm-import SA with cluster-admin.
  # The pattern creates this SA automatically on spokes (platform-users chart).
  # On each spoke, after VP install completes, run:
  #   oc create token -n kube-system acm-import --duration=87600h
  - name: spoke-credentials
    fields:
      - name: east-token
        value: "East spoke cluster-admin SA token (see instructions above)"
      - name: east-api-url
        value: "https://api.<east_domain>:6443"
      - name: west-token
        value: "West spoke cluster-admin SA token (see instructions above)"
      - name: west-api-url
        value: "https://api.<west_domain>:6443"
